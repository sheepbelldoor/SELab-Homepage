generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id          String   @id @default(cuid())
  title       String
  titleEn     String   @default("")
  content     String
  contentEn   String   @default("")
  category    String   @default("news") // "news" | "notice"
  published   Boolean  @default(false)
  pinned      Boolean  @default(false)
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Member {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?
  photo       String?
  role        String   // "professor" | "postdoc" | "msphd" | "phd" | "ms" | "intern" | "alumni"
  bio         String?
  bioEn       String?
  interest    String?
  interestEn  String?
  email       String?
  homepage    String?
  github      String?
  scholar     String?
  cvUrl       String?
  authorAliases String @default("[]") // JSON array of name variants for publication matching
  education   String   @default("[]") // JSON array of education entries
  educationEn String   @default("[]") // JSON array of education entries (English)
  awards      String   @default("[]") // JSON array of honors & awards entries
  awardsEn    String   @default("[]") // JSON array of honors & awards entries (English)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Publication {
  id          String   @id @default(cuid())
  title       String
  authors     String
  venue       String
  year        Int
  tags        String   @default("[]") // JSON array of tags (e.g. ["ICSE", "Best Paper"])
  url         String?
  pdfUrl      String?
  doiUrl      String?
  projectUrl  String?
  codeUrl     String?
  videoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id            String   @id @default(cuid())
  title         String
  titleEn       String   @default("")
  description   String
  descriptionEn String   @default("")
  participants  String?
  status        String   @default("ongoing") // "ongoing" | "completed"
  featured      Boolean  @default(false)
  imageUrl      String?
  demoUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Research {
  id            String   @id @default(cuid())
  title         String
  titleEn       String   @default("")
  description   String
  descriptionEn String   @default("")
  icon          String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteConfig {
  id              String   @id @default("main")
  labName         String   @default("SELab")
  labNameEn       String   @default("")
  tagline         String   @default("Software Engineering Laboratory")
  taglineEn       String   @default("")
  description     String   @default("")
  descriptionEn   String   @default("")
  bannerUrl       String?
  address         String   @default("")
  addressEn       String   @default("")
  building        String   @default("")
  buildingEn      String   @default("")
  email           String   @default("")
  phone           String   @default("")
  mapUrl          String?
  joinUsContent   String   @default("")
  joinUsContentEn String   @default("")
  aboutContent    String   @default("")
  aboutContentEn  String   @default("")
  updatedAt       DateTime @updatedAt
}
